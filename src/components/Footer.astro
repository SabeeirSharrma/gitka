---
import DefaultFooter from '@astrojs/starlight/components/Footer.astro';

const { ...props } = Astro.props;
---

<DefaultFooter {...props} />

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">Transit</span>
      <span class="footer-tagline">Letting languages just talk to each other.</span>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h4>Docs</h4>
        <a href="/transit/guides/getting-started/">Getting Started</a>
        <a href="/transit/reference/api-reference/">API Reference</a>
        <a href="/transit/reference/architecture/">Architecture</a>
      </div>
      <div class="footer-col">
        <h4>Quick Guides (Concepts)</h4>
        <a href="/transit/reference/export-tiers/">Export Tiers</a>
        <a href="/transit/reference/binary-protocol/">Binary Protocol</a>
        <a href="/transit/guides/contributing/">Contributing</a>
      </div>
      <div class="footer-col">
        <h4>Community</h4>
        <a href="https://github.com/sabeeirsharrma/transit" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>Built with <a href="https://starlight.astro.build" target="_blank" rel="noopener">Starlight</a></span>
      <span>Made with ❤️ by Sabeeir Sharrma</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--sl-color-hairline);
    padding: 2.5rem 1.5rem 1.5rem;
    margin-top: 3rem;
  }

  .footer-inner {
    max-width: var(--sl-content-width, 72rem);
    margin: 0 auto;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 2rem;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-text);
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--sl-color-text-muted);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-col h4 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-text);
    margin: 0 0 0.75rem;
  }

  .footer-col a {
    display: block;
    font-size: 0.875rem;
    color: var(--sl-color-text-muted);
    text-decoration: none;
    padding: 0.2rem 0;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: var(--sl-color-accent-high);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sl-color-hairline);
    font-size: 0.8rem;
    color: var(--sl-color-text-muted);
  }

  .footer-bottom a {
    color: var(--sl-color-accent);
    text-decoration: none;
  }

  .footer-bottom a:hover {
    text-decoration: underline;
  }

  @media (max-width: 50rem) {
    .footer-links {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 30rem) {
    .footer-links {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
