{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri/dev/packages/cli/schema.json",
  "productName": "Gitka",
  "version": "0.6.0",
  "identifier": "dev.gitka.app",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Gitka",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' asset: https://asset.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "Gitka"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Compressed git repo backups on physical media",
    "longDescription": "Gitka creates compressed, physical-media local copies of your GitHub/GitFlare repos with offline commit capability and LAN-based sharing.",
    "linux": {
      "deb": {
        "depends": ["git"]
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
